VITE_API_URL=http://localhost:3001

# Backend admin bootstrap, set these on the deployed backend to create an admin
# account on startup. The account is created once and skipped if it already exists.
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=replace-with-a-strong-password
# ADMIN_GYM_NAME=7up Gym

# Backend CORS allowlist. Use commas for multiple frontend domains.
# FRONTEND_URL=https://your-site.vercel.app,https://www.yourdomain.com

# Production example for Vercel:
# VITE_API_URL=https://your-render-service.onrender.com
