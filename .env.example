# ---------------------------------------------------------------------------
# Local settings for the Docker setup. Safe default values, no real secrets.
# START_SYSTEM.bat copies this file to ".env" the first time you run it.
# You normally do NOT need to change anything here.
# ---------------------------------------------------------------------------

# Database (runs inside Docker, no install needed)
POSTGRES_USER=gym
POSTGRES_PASSWORD=gym_local_password
POSTGRES_DB=gym_ops

# Ports opened on your computer
FRONTEND_PORT=5173
BACKEND_PORT=3001

# Login security key (any long random text is fine for local use)
JWT_SECRET=change-me-local-dev-secret

# The first admin account, created automatically on first start.
# Use these to log in. Password must be at least 8 characters.
ADMIN_EMAIL=admin@gym.local
ADMIN_PASSWORD=admin12345
ADMIN_GYM_NAME=My Gym
